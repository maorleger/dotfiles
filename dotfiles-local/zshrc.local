# WSL and other linux distros
[ -s "/home/linuxbrew/.linuxbrew" ] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
# OSX
[ -s "/opt/homebrew" ] && eval "$(/opt/homebrew/bin/brew shellenv)"

# Rust
[[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

export PATH=$HOME/.local/bin:$PATH

export PATH=$PATH:/usr/local/go/bin

eval "$($HOME/.local/bin/mise activate zsh)"


# Enable remote caching in repo
export TURBO_TOKEN=1
export TURBO_CACHE=local:rw,remote:r
